{
  "version": 2,
  "buildCommand": "cd artifacts/api-server && pnpm run build",
  "outputDirectory": "artifacts/api-server/dist",
  "functions": {
    "artifacts/api-server/dist/index.cjs": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/dist/index.cjs"
    }
  ]
}

{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/package.json",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["artifacts/api-server/dist/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/dist/index.cjs"
    }
  ]
}
